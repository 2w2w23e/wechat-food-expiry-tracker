<view class="page">
  <view class="header">
    <view class="eyebrow">食品到期列表</view>
    <view class="title">食期管家</view>
    <view class="desc">按到期日查看食品，支持筛选、统计和本机保存</view>
  </view>

  <view class="storage-notice">数据保存在本机小程序内，暂不支持多设备同步。</view>

  <button class="add-toggle" bindtap="toggleAddForm">
    {{showAddForm ? '收起表单' : '新增食品'}}
  </button>

  <view class="add-form" wx:if="{{showAddForm}}">
    <view class="form-title">新增食品</view>

    <view class="form-error" wx:if="{{formError}}">{{formError}}</view>

    <view class="field">
      <view class="field-label">食品名称</view>
      <input class="field-input" value="{{addForm.name}}" data-field="name" bindinput="updateAddForm" placeholder="例如：牛奶" />
    </view>

    <view class="field">
      <view class="field-label">分类</view>
      <input class="field-input" value="{{addForm.category}}" data-field="category" bindinput="updateAddForm" placeholder="例如：乳制品" />
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">数量</view>
        <input class="field-input" type="digit" value="{{addForm.quantity}}" data-field="quantity" bindinput="updateAddForm" placeholder="例如：2" />
      </view>
      <view class="field half">
        <view class="field-label">剩余数量</view>
        <input class="field-input" type="digit" value="{{addForm.remainingQuantity}}" data-field="remainingQuantity" bindinput="updateAddForm" placeholder="例如：1" />
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">单位</view>
        <input class="field-input" value="{{addForm.unit}}" data-field="unit" bindinput="updateAddForm" placeholder="例如：盒" />
      </view>
      <view class="field half">
        <view class="field-label">保存方式</view>
        <input class="field-input" value="{{addForm.storageMethod}}" data-field="storageMethod" bindinput="updateAddForm" placeholder="例如：冷藏" />
      </view>
    </view>

    <view class="field">
      <view class="field-label">生产日期</view>
      <picker mode="date" value="{{addForm.productionDate}}" data-field="productionDate" bindchange="updateAddForm">
        <view class="field-input picker-value {{addForm.productionDate ? '' : 'picker-placeholder'}}">
          {{addForm.productionDate || '请选择生产日期'}}
        </view>
      </picker>
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">保质期</view>
        <input class="field-input" type="number" value="{{addForm.shelfLifeValue}}" data-field="shelfLifeValue" bindinput="updateAddForm" placeholder="例如：30" />
      </view>
      <view class="field half">
        <view class="field-label">保质期单位</view>
        <picker mode="selector" range="{{shelfLifeUnitOptions}}" range-key="label" value="{{shelfLifeUnitIndex}}" data-field="shelfLifeUnit" bindchange="updateAddForm">
          <view class="field-input picker-value">{{shelfLifeUnitLabel}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <view class="field-label">最终可食用日期</view>
      <picker mode="date" value="{{addForm.expiryDate}}" data-field="expiryDate" bindchange="updateAddForm">
        <view class="field-input picker-value {{addForm.expiryDate ? '' : 'picker-placeholder'}}">
          {{addForm.expiryDate || '请选择最终可食用日期'}}
        </view>
      </picker>
      <view class="field-hint">不知道生产日期也可以，只填写最终可食用日期即可。</view>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="field-textarea" value="{{addForm.notes}}" data-field="notes" bindinput="updateAddForm" placeholder="可填写存放位置或其他提醒" />
    </view>

    <button class="submit-button" bindtap="submitAddForm">保存食品</button>
  </view>

  <view class="statistics-panel">
    <view class="section-title">食品统计</view>
    <view class="statistics-list">
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.totalCount}}</text>
        <text class="statistics-label">总食品数</text>
      </view>
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.soonCount}}</text>
        <text class="statistics-label">即将过期</text>
      </view>
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.expiredCount}}</text>
        <text class="statistics-label">已过期</text>
      </view>
    </view>
  </view>

  <view class="filter-panel">
    <view class="section-title">筛选食品</view>
    <view class="filter-buttons">
      <button
        class="filter-button {{activeFilterType === item.type ? 'filter-button-active' : ''}}"
        wx:for="{{filterOptions}}"
        wx:key="type"
        data-filter="{{item.type}}"
        bindtap="changeStatusFilter"
      >
        {{item.label}}
      </button>
    </view>

    <picker wx:if="{{categoryFilterOptions.length}}" mode="selector" range="{{categoryFilterOptions}}" range-key="label" value="{{categoryFilterIndex}}" bindchange="changeCategoryFilter">
      <view class="category-filter {{activeFilterType === 'category' ? 'category-filter-active' : ''}}">
        <text class="category-filter-label">分类</text>
        <text class="category-filter-value">{{activeFilterType === 'category' ? activeCategoryLabel : '选择分类'}}</text>
      </view>
    </picker>

    <view class="category-filter category-filter-disabled" wx:else>
      <text class="category-filter-label">分类</text>
      <text class="category-filter-value">暂无分类</text>
    </view>

    <view class="current-filter">{{currentFilterText}}</view>
  </view>

  <view class="detail-panel" wx:if="{{selectedFood}}">
    <view class="detail-header">
      <view class="detail-title-group">
        <view class="detail-eyebrow">食品详情</view>
        <view class="detail-title">{{selectedFood.name || '未填写'}}</view>
      </view>
      <view class="status-pill {{selectedFood.statusClass}}">{{selectedFood.statusText || '未填写到期日'}}</view>
    </view>

    <block wx:if="{{isEditing}}">
      <view class="edit-form">
        <view class="form-title">编辑食品</view>

        <view class="form-error" wx:if="{{editFormError}}">{{editFormError}}</view>

        <view class="field">
          <view class="field-label">食品名称</view>
          <input class="field-input" value="{{editForm.name}}" data-field="name" bindinput="updateEditForm" placeholder="例如：牛奶" />
        </view>

        <view class="field">
          <view class="field-label">分类</view>
          <input class="field-input" value="{{editForm.category}}" data-field="category" bindinput="updateEditForm" placeholder="例如：乳制品" />
        </view>

        <view class="field-row">
          <view class="field half">
            <view class="field-label">数量</view>
            <input class="field-input" type="digit" value="{{editForm.quantity}}" data-field="quantity" bindinput="updateEditForm" placeholder="例如：2" />
          </view>
          <view class="field half">
            <view class="field-label">剩余数量</view>
            <input class="field-input" type="digit" value="{{editForm.remainingQuantity}}" data-field="remainingQuantity" bindinput="updateEditForm" placeholder="例如：1" />
          </view>
        </view>

        <view class="field-row">
          <view class="field half">
            <view class="field-label">单位</view>
            <input class="field-input" value="{{editForm.unit}}" data-field="unit" bindinput="updateEditForm" placeholder="例如：盒" />
          </view>
          <view class="field half">
            <view class="field-label">保存方式</view>
            <input class="field-input" value="{{editForm.storageMethod}}" data-field="storageMethod" bindinput="updateEditForm" placeholder="例如：冷藏" />
          </view>
        </view>

        <view class="field">
          <view class="field-label">生产日期</view>
          <picker mode="date" value="{{editForm.productionDate}}" data-field="productionDate" bindchange="updateEditForm">
            <view class="field-input picker-value {{editForm.productionDate ? '' : 'picker-placeholder'}}">
              {{editForm.productionDate || '请选择生产日期'}}
            </view>
          </picker>
        </view>

        <view class="field-row">
          <view class="field half">
            <view class="field-label">保质期</view>
            <input class="field-input" type="number" value="{{editForm.shelfLifeValue}}" data-field="shelfLifeValue" bindinput="updateEditForm" placeholder="例如：30" />
          </view>
          <view class="field half">
            <view class="field-label">保质期单位</view>
            <picker mode="selector" range="{{shelfLifeUnitOptions}}" range-key="label" value="{{editShelfLifeUnitIndex}}" data-field="shelfLifeUnit" bindchange="updateEditForm">
              <view class="field-input picker-value">{{editShelfLifeUnitLabel}}</view>
            </picker>
          </view>
        </view>

        <view class="field">
          <view class="field-label">最终可食用日期</view>
          <picker mode="date" value="{{editForm.expiryDate}}" data-field="expiryDate" bindchange="updateEditForm">
            <view class="field-input picker-value {{editForm.expiryDate ? '' : 'picker-placeholder'}}">
              {{editForm.expiryDate || '请选择最终可食用日期'}}
            </view>
          </picker>
          <view class="field-hint">留空时，会根据生产日期和保质期计算。</view>
        </view>

        <view class="field">
          <view class="field-label">备注</view>
          <textarea class="field-textarea" value="{{editForm.notes}}" data-field="notes" bindinput="updateEditForm" placeholder="可填写存放位置或其他提醒" />
        </view>

        <view class="edit-actions">
          <button class="submit-button edit-submit-button" bindtap="submitEditForm">保存修改</button>
          <button class="cancel-edit-button" bindtap="cancelEditFood">取消编辑</button>
        </view>
      </view>
    </block>

    <block wx:if="{{!isEditing}}">
      <view class="detail-actions">
        <button class="edit-detail-button" bindtap="startEditSelectedFood">编辑</button>
        <button class="delete-detail-button" bindtap="confirmDeleteSelectedFood">删除</button>
      </view>

      <view class="detail-list">
        <view class="detail-row" wx:for="{{selectedFoodDetails}}" wx:key="label">
          <text class="detail-label">{{item.label}}</text>
          <text class="detail-value">{{item.value}}</text>
        </view>
      </view>

      <button class="close-detail-button" bindtap="closeFoodDetail">关闭</button>
    </block>
  </view>

  <view class="food-list" wx:if="{{foods.length}}">
    <view class="food-card" wx:for="{{foods}}" wx:key="id">
      <view class="card-header">
        <view class="food-name">{{item.name}}</view>
        <view class="status-pill {{item.statusClass}}">{{item.statusText}}</view>
      </view>

      <view class="info-row">
        <text class="label">分类：</text>
        <text class="value">{{item.categoryText}}</text>
      </view>
      <view class="info-row">
        <text class="label">数量：</text>
        <text class="value">{{item.quantity}} {{item.unit}} / 剩余 {{item.remainingQuantity}} {{item.unit}}</text>
      </view>
      <view class="info-row">
        <text class="label">保存方式：</text>
        <text class="value">{{item.storageMethodText}}</text>
      </view>
      <view class="info-row">
        <text class="label">到期日：</text>
        <text class="value">{{item.expiryDateText}}</text>
      </view>
      <view class="info-row">
        <text class="label">状态：</text>
        <text class="value">{{item.statusText}}</text>
      </view>

      <button class="detail-button" data-id="{{item.id}}" bindtap="showFoodDetail">查看详情</button>
    </view>
  </view>

  <view class="empty" wx:else>{{rawFoods.length ? '当前筛选下暂无食品' : '暂无食品数据'}}</view>
</view>
