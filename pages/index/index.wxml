<view class="page">
  <view class="header">
    <view class="eyebrow">食品到期列表</view>
    <view class="title">食期管家</view>
    <view class="desc">按到期日查看食品，支持筛选、统计和本机保存</view>
  </view>

  <view class="storage-notice">数据保存在本机小程序内，暂不支持多设备同步。</view>

  <button class="add-toggle" bindtap="toggleAddForm">
    {{showAddForm ? '收起表单' : '新增食品'}}
  </button>

  <view class="add-form" wx:if="{{showAddForm}}">
    <view class="form-title">新增食品</view>

    <view class="form-error" wx:if="{{formError}}">{{formError}}</view>

    <view class="field">
      <view class="field-label">食品名称</view>
      <input class="field-input" value="{{addForm.name}}" data-field="name" bindinput="updateAddForm" placeholder="例如：牛奶" />
    </view>

    <view class="field">
      <view class="field-label">分类</view>
      <input class="field-input" value="{{addForm.category}}" data-field="category" bindinput="updateAddForm" placeholder="例如：dairy 或乳制品" />
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">数量</view>
        <input class="field-input" type="digit" value="{{addForm.quantity}}" data-field="quantity" bindinput="updateAddForm" placeholder="例如：2" />
      </view>
      <view class="field half">
        <view class="field-label">剩余数量</view>
        <input class="field-input" type="digit" value="{{addForm.remainingQuantity}}" data-field="remainingQuantity" bindinput="updateAddForm" placeholder="例如：1" />
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">单位</view>
        <input class="field-input" value="{{addForm.unit}}" data-field="unit" bindinput="updateAddForm" placeholder="例如：盒" />
      </view>
      <view class="field half">
        <view class="field-label">保存方式</view>
        <input class="field-input" value="{{addForm.storageMethod}}" data-field="storageMethod" bindinput="updateAddForm" placeholder="例如：冷藏" />
      </view>
    </view>

    <view class="field">
      <view class="field-label">生产日期</view>
      <picker mode="date" value="{{addForm.productionDate}}" data-field="productionDate" bindchange="updateAddForm">
        <view class="field-input picker-value {{addForm.productionDate ? '' : 'picker-placeholder'}}">
          {{addForm.productionDate || '请选择生产日期'}}
        </view>
      </picker>
    </view>

    <view class="field-row">
      <view class="field half">
        <view class="field-label">保质期</view>
        <input class="field-input" type="number" value="{{addForm.shelfLifeValue}}" data-field="shelfLifeValue" bindinput="updateAddForm" placeholder="例如：30" />
      </view>
      <view class="field half">
        <view class="field-label">保质期单位</view>
        <picker mode="selector" range="{{shelfLifeUnitOptions}}" range-key="label" value="{{shelfLifeUnitIndex}}" data-field="shelfLifeUnit" bindchange="updateAddForm">
          <view class="field-input picker-value">{{shelfLifeUnitLabel}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <view class="field-label">最终可食用日期</view>
      <picker mode="date" value="{{addForm.expiryDate}}" data-field="expiryDate" bindchange="updateAddForm">
        <view class="field-input picker-value {{addForm.expiryDate ? '' : 'picker-placeholder'}}">
          {{addForm.expiryDate || '请选择最终可食用日期'}}
        </view>
      </picker>
      <view class="field-hint">不知道生产日期也可以，只填写最终可食用日期即可。</view>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="field-textarea" value="{{addForm.notes}}" data-field="notes" bindinput="updateAddForm" placeholder="可填写存放位置或其他提醒" />
    </view>

    <button class="submit-button" bindtap="submitAddForm">保存食品</button>
  </view>

  <view class="statistics-panel">
    <view class="section-title">食品统计</view>
    <view class="statistics-list">
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.totalCount}}</text>
        <text class="statistics-label">总食品数</text>
      </view>
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.soonCount}}</text>
        <text class="statistics-label">即将过期</text>
      </view>
      <view class="statistics-item">
        <text class="statistics-number">{{statistics.expiredCount}}</text>
        <text class="statistics-label">已过期</text>
      </view>
    </view>
  </view>

  <view class="filter-panel">
    <view class="section-title">筛选食品</view>

    <view class="filter-controls">
      <view class="filter-control status-filter-control">
        <view class="filter-label">状态筛选</view>
        <view class="status-filter-buttons">
          <button
            class="status-filter-button {{statusFilter === item.value ? 'status-filter-button-active' : ''}}"
            wx:for="{{statusFilterOptions}}"
            wx:key="value"
            data-filter="{{item.value}}"
            bindtap="changeStatusFilter"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view class="filter-control category-filter-control">
        <view class="filter-label">分类筛选</view>
        <button class="category-open-button" bindtap="openCategoryPanel">
          <text class="category-current-text">当前分类：{{categoryFilterLabel}}</text>
          <text class="category-open-action">选择分类</text>
        </button>
      </view>
    </view>

    <view class="current-filter">{{currentFilterText}}</view>
  </view>

  <view class="category-panel-mask" wx:if="{{showCategoryPanel}}" bindtap="closeCategoryPanel">
    <view class="category-panel" catchtap="stopCategoryPanelTap">
      <view class="category-panel-header">
        <view class="category-panel-title">选择分类</view>
        <button class="category-panel-close" bindtap="closeCategoryPanel">关闭</button>
      </view>

      <input
        class="category-search-input"
        value="{{categorySearchText}}"
        bindinput="updateCategorySearch"
        placeholder="输入分类名称"
        focus="{{showCategoryPanel}}"
      />

      <scroll-view class="category-result-scroll" scroll-y="true">
        <view class="category-result-list" wx:if="{{categorySearchResults.length}}">
          <button
            class="category-result-button {{categoryFilter === item.value ? 'category-result-button-active' : ''}}"
            wx:for="{{categorySearchResults}}"
            wx:key="value"
            data-category="{{item.value}}"
            bindtap="selectCategoryFilter"
          >
            {{item.label}}
          </button>
        </view>

        <view class="category-search-empty" wx:else>没有匹配的分类</view>
      </scroll-view>

      <button class="category-cancel-button" bindtap="closeCategoryPanel">取消</button>
    </view>
  </view>

  <view class="food-list" wx:if="{{foods.length}}">
    <view class="food-card" wx:for="{{foods}}" wx:key="id">
      <view class="card-header">
        <view class="food-name">{{item.name}}</view>
        <view class="status-pill {{item.statusClass}}">{{item.statusText}}</view>
      </view>

      <view class="info-row" wx:if="{{item.hasCategoryText}}">
        <text class="label">分类：</text>
        <text class="value">{{item.categoryText}}</text>
      </view>
      <view class="info-row">
        <text class="label">数量：</text>
        <text class="value">{{item.quantity}} {{item.unit}} / 剩余 {{item.remainingQuantity}} {{item.unit}}</text>
      </view>
      <view class="info-row" wx:if="{{item.hasStorageMethodText}}">
        <text class="label">保存方式：</text>
        <text class="value">{{item.storageMethodText}}</text>
      </view>
      <view class="info-row">
        <text class="label">到期日：</text>
        <text class="value">{{item.expiryDateText}}</text>
      </view>
      <view class="info-row">
        <text class="label">状态：</text>
        <text class="value">{{item.statusText}}</text>
      </view>

      <button class="detail-button" data-id="{{item.id}}" bindtap="viewFoodDetail">查看详情</button>
    </view>
  </view>

  <view class="empty" wx:else>{{rawFoods.length ? '当前筛选下没有食品' : '暂无食品数据'}}</view>
</view>
