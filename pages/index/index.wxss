.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  background: #f5f6f0;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  margin-bottom: 16rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.4;
}

.title {
  color: #1f241d;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.desc {
  margin-top: 16rpx;
  color: #4a5047;
  font-size: 30rpx;
  line-height: 1.6;
}

.storage-notice {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #3f473b;
  font-size: 30rpx;
  line-height: 1.5;
}

.add-toggle,
.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0 0 28rpx;
  border-radius: 8rpx;
  background: #2f6b48;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.add-form {
  margin-bottom: 32rpx;
  padding: 28rpx;
  border: 1rpx solid #d7ded0;
  border-radius: 8rpx;
  background: #ffffff;
}

.form-title {
  margin-bottom: 24rpx;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.form-error {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #9f352e;
  border-radius: 8rpx;
  background: #fff0ee;
  color: #87251f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field {
  margin-bottom: 24rpx;
}

.field-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.field-label {
  margin-bottom: 12rpx;
  color: #343a32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #cfd8c8;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field-textarea {
  min-height: 144rpx;
}

.picker-value {
  color: #20231f;
}

.picker-placeholder {
  color: #7a8175;
}

.field-hint {
  margin-top: 10rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.45;
}

.submit-button {
  margin: 8rpx 0 0;
  background: #215c3a;
}

.statistics-panel,
.filter-panel {
  margin: 0 0 32rpx;
  padding: 28rpx;
  border: 1rpx solid #d7ded0;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-title {
  margin-bottom: 20rpx;
  color: #20231f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.statistics-list {
  display: flex;
  gap: 16rpx;
}

.statistics-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx 12rpx;
  border: 1rpx solid #dde6d7;
  border-radius: 8rpx;
  background: #fbfcf8;
  text-align: center;
}

.statistics-number {
  display: block;
  color: #1f241d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.statistics-label {
  display: block;
  margin-top: 8rpx;
  color: #4a5047;
  font-size: 26rpx;
  line-height: 1.35;
}

.filter-controls {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-control {
  min-width: 0;
}

.filter-label {
  margin-bottom: 12rpx;
  color: #263022;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.status-filter-buttons {
  display: flex;
  gap: 12rpx;
}

.status-filter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  box-sizing: border-box;
  min-height: 84rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 2rpx solid #6f7c67;
  border-radius: 8rpx;
  background: #ffffff;
  color: #263022;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
}

.status-filter-button-active {
  border-color: #215c3a;
  background: #e7f3e9;
  color: #1f5135;
}

.category-open-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  width: 100%;
  min-height: 84rpx;
  margin: 0;
  padding: 16rpx 18rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #263022;
  font-size: 30rpx;
  line-height: 1.4;
  text-align: left;
}

.category-current-text {
  flex: 1;
  min-width: 0;
  font-weight: 700;
  word-break: break-all;
}

.category-open-action {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #58624f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.current-filter {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f5f6f0;
  color: #343a32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
}

.category-panel-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(31, 36, 29, 0.44);
}

.category-panel {
  box-sizing: border-box;
  width: 100%;
  max-height: 82vh;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.category-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.category-panel-title {
  flex: 1;
  min-width: 0;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.category-panel-close,
.category-cancel-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 0;
  border: 2rpx solid #6a6f78;
  border-radius: 8rpx;
  background: #ffffff;
  color: #4a5059;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.category-panel-close {
  flex: 0 0 auto;
  min-width: 176rpx;
  padding: 0 28rpx;
  white-space: nowrap;
  word-break: keep-all;
}

.category-search-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 84rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 18rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 32rpx;
  line-height: 1.4;
}

.category-result-scroll {
  max-height: 560rpx;
}

.category-result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.category-result-button {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #263022;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: left;
}

.category-result-button-active {
  border-color: #215c3a;
  background: #e7f3e9;
  color: #1f5135;
}

.category-search-empty {
  padding: 36rpx 20rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #4a5047;
  font-size: 32rpx;
  line-height: 1.5;
  text-align: center;
}

.category-cancel-button {
  width: 100%;
  margin-top: 22rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.food-card {
  padding: 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.food-name {
  flex: 1;
  color: #20231f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.status-pill {
  min-width: 152rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #5d6b57;
  border-radius: 8rpx;
  color: #243020;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.status-expired {
  border-color: #9f352e;
  background: #fff0ee;
  color: #87251f;
}

.status-today {
  border-color: #b65c1e;
  background: #fff3e8;
  color: #8b4315;
}

.status-soon {
  border-color: #9b7a1f;
  background: #fff8d9;
  color: #6b520d;
}

.status-normal {
  border-color: #497656;
  background: #edf8ef;
  color: #285735;
}

.status-unknown {
  border-color: #6a6f78;
  background: #f1f3f6;
  color: #4a5059;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-top: 1rpx solid #eef0e8;
  font-size: 30rpx;
  line-height: 1.55;
}

.label {
  flex: 0 0 172rpx;
  color: #5b6257;
}

.value {
  flex: 1;
  color: #222820;
  word-break: break-all;
}

.detail-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin: 24rpx 0 0;
  border: 2rpx solid #2f6b48;
  border-radius: 8rpx;
  background: #ffffff;
  color: #215c3a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.detail-button[disabled] {
  border-color: #9aa395;
  background: #f1f3ee;
  color: #5d6659;
}

.empty {
  padding: 48rpx 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
  color: #4a5047;
  font-size: 32rpx;
  line-height: 1.5;
  text-align: center;
}
