.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  background: #f5f6f0;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  margin-bottom: 16rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.4;
}

.title {
  color: #1f241d;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.desc {
  margin-top: 16rpx;
  color: #4a5047;
  font-size: 30rpx;
  line-height: 1.6;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.food-card {
  padding: 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.food-name {
  flex: 1;
  color: #20231f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.status-pill {
  min-width: 152rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #5d6b57;
  border-radius: 8rpx;
  color: #243020;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.status-expired {
  border-color: #9f352e;
  background: #fff0ee;
  color: #87251f;
}

.status-today {
  border-color: #b65c1e;
  background: #fff3e8;
  color: #8b4315;
}

.status-soon {
  border-color: #9b7a1f;
  background: #fff8d9;
  color: #6b520d;
}

.status-normal {
  border-color: #497656;
  background: #edf8ef;
  color: #285735;
}

.status-unknown {
  border-color: #6a6f78;
  background: #f1f3f6;
  color: #4a5059;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-top: 1rpx solid #eef0e8;
  font-size: 30rpx;
  line-height: 1.55;
}

.label {
  flex: 0 0 172rpx;
  color: #5b6257;
}

.value {
  flex: 1;
  color: #222820;
  word-break: break-all;
}

.empty {
  padding: 48rpx 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
  color: #4a5047;
  font-size: 32rpx;
  line-height: 1.5;
  text-align: center;
}
