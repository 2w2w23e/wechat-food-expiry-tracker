.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  background: #f5f6f0;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  margin-bottom: 16rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.4;
}

.title {
  color: #1f241d;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.desc {
  margin-top: 16rpx;
  color: #4a5047;
  font-size: 30rpx;
  line-height: 1.6;
}

.add-toggle,
.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0 0 28rpx;
  border-radius: 8rpx;
  background: #2f6b48;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.storage-notice {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #3f473b;
  font-size: 30rpx;
  line-height: 1.5;
}

.add-form {
  margin-bottom: 32rpx;
  padding: 28rpx;
  border: 1rpx solid #d7ded0;
  border-radius: 8rpx;
  background: #ffffff;
}

.form-title {
  margin-bottom: 24rpx;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.form-error {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #9f352e;
  border-radius: 8rpx;
  background: #fff0ee;
  color: #87251f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field {
  margin-bottom: 24rpx;
}

.field-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.field-label {
  margin-bottom: 12rpx;
  color: #343a32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #cfd8c8;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field-textarea {
  min-height: 144rpx;
}

.picker-value {
  color: #20231f;
}

.picker-placeholder {
  color: #7a8175;
}

.field-hint {
  margin-top: 10rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.45;
}

.submit-button {
  margin: 8rpx 0 0;
  background: #215c3a;
}

.statistics-panel,
.filter-panel {
  margin: 0 0 32rpx;
  padding: 28rpx;
  border: 1rpx solid #d7ded0;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-title {
  margin-bottom: 20rpx;
  color: #20231f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.statistics-list {
  display: flex;
  gap: 16rpx;
}

.statistics-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx 12rpx;
  border: 1rpx solid #dde6d7;
  border-radius: 8rpx;
  background: #fbfcf8;
  text-align: center;
}

.statistics-number {
  display: block;
  color: #1f241d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.statistics-label {
  display: block;
  margin-top: 8rpx;
  color: #4a5047;
  font-size: 26rpx;
  line-height: 1.35;
}

.filter-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 2rpx solid #6f7c67;
  border-radius: 8rpx;
  background: #ffffff;
  color: #263022;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.filter-button-active {
  border-color: #215c3a;
  background: #e7f3e9;
  color: #1f5135;
}

.category-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  border: 2rpx solid #6f7c67;
  border-radius: 8rpx;
  background: #ffffff;
  color: #263022;
  font-size: 30rpx;
  line-height: 1.35;
}

.category-filter-active {
  border-color: #215c3a;
  background: #e7f3e9;
  color: #1f5135;
}

.category-filter-disabled {
  border-color: #c6cec0;
  background: #f5f6f0;
  color: #6f766b;
}

.category-filter-label {
  flex: 0 0 auto;
  font-weight: 700;
}

.category-filter-value {
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.current-filter {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 8rpx;
  background: #f5f6f0;
  color: #343a32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.food-card {
  padding: 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.food-name {
  flex: 1;
  color: #20231f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.status-pill {
  min-width: 152rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #5d6b57;
  border-radius: 8rpx;
  color: #243020;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.status-expired {
  border-color: #9f352e;
  background: #fff0ee;
  color: #87251f;
}

.status-today {
  border-color: #b65c1e;
  background: #fff3e8;
  color: #8b4315;
}

.status-soon {
  border-color: #9b7a1f;
  background: #fff8d9;
  color: #6b520d;
}

.status-normal {
  border-color: #497656;
  background: #edf8ef;
  color: #285735;
}

.status-unknown {
  border-color: #6a6f78;
  background: #f1f3f6;
  color: #4a5059;
}

.detail-button,
.close-detail-button,
.edit-detail-button,
.delete-detail-button,
.cancel-edit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 24rpx 0 0;
  border: 2rpx solid #2f6b48;
  border-radius: 8rpx;
  background: #ffffff;
  color: #215c3a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.detail-actions,
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin: 0 0 24rpx;
}

.detail-actions .edit-detail-button,
.detail-actions .delete-detail-button,
.edit-actions .submit-button,
.edit-actions .cancel-edit-button {
  flex: 1;
  min-width: 0;
  margin: 0;
}

.delete-detail-button {
  border-color: #9f352e;
  color: #87251f;
}

.cancel-edit-button {
  border-color: #6a6f78;
  color: #4a5059;
}

.edit-form {
  padding-top: 4rpx;
}

.edit-submit-button {
  background: #215c3a;
}

.detail-panel {
  margin: 0 0 32rpx;
  padding: 32rpx;
  border: 2rpx solid #b9c9b2;
  border-radius: 8rpx;
  background: #ffffff;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.detail-title-group {
  flex: 1;
  min-width: 0;
}

.detail-eyebrow {
  margin-bottom: 8rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.4;
}

.detail-title {
  color: #20231f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.detail-list {
  border-top: 1rpx solid #eef0e8;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef0e8;
  font-size: 30rpx;
  line-height: 1.55;
}

.detail-label {
  flex: 0 0 208rpx;
  color: #5b6257;
  font-weight: 700;
}

.detail-value {
  flex: 1;
  color: #222820;
  word-break: break-all;
}

.close-detail-button {
  background: #215c3a;
  color: #ffffff;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-top: 1rpx solid #eef0e8;
  font-size: 30rpx;
  line-height: 1.55;
}

.label {
  flex: 0 0 172rpx;
  color: #5b6257;
}

.value {
  flex: 1;
  color: #222820;
  word-break: break-all;
}

.empty {
  padding: 48rpx 32rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #ffffff;
  color: #4a5047;
  font-size: 32rpx;
  line-height: 1.5;
  text-align: center;
}
