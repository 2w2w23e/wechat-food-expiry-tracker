.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  background: #f5f6f0;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  margin-bottom: 16rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.4;
}

.title {
  color: #1f241d;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.desc {
  margin-top: 16rpx;
  color: #4a5047;
  font-size: 30rpx;
  line-height: 1.6;
}

.storage-notice {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #3f473b;
  font-size: 30rpx;
  line-height: 1.5;
}

.detail-panel,
.empty {
  padding: 32rpx;
  border: 1rpx solid #d7ded0;
  border-radius: 8rpx;
  background: #ffffff;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.detail-title-group {
  flex: 1;
  min-width: 0;
}

.detail-name {
  color: #20231f;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.detail-subtitle {
  margin-top: 10rpx;
  color: #58624f;
  font-size: 30rpx;
  line-height: 1.4;
  word-break: break-all;
}

.status-pill {
  min-width: 152rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #5d6b57;
  border-radius: 8rpx;
  color: #243020;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.status-expired {
  border-color: #9f352e;
  background: #fff0ee;
  color: #87251f;
}

.status-today {
  border-color: #b65c1e;
  background: #fff3e8;
  color: #8b4315;
}

.status-soon {
  border-color: #9b7a1f;
  background: #fff8d9;
  color: #6b520d;
}

.status-normal {
  border-color: #497656;
  background: #edf8ef;
  color: #285735;
}

.status-unknown {
  border-color: #6a6f78;
  background: #f1f3f6;
  color: #4a5059;
}

.detail-actions,
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin: 0 0 28rpx;
}

.edit-detail-button,
.delete-detail-button,
.cancel-edit-button,
.back-button,
.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin: 0;
  border: 2rpx solid #2f6b48;
  border-radius: 8rpx;
  background: #ffffff;
  color: #215c3a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
}

.detail-actions .edit-detail-button,
.detail-actions .delete-detail-button,
.edit-actions .submit-button,
.edit-actions .cancel-edit-button {
  flex: 1;
  min-width: 0;
}

.submit-button,
.back-button {
  background: #215c3a;
  color: #ffffff;
}

.delete-detail-button {
  border-color: #9f352e;
  color: #87251f;
}

.cancel-edit-button {
  border-color: #6a6f78;
  color: #4a5059;
}

.detail-list {
  border-top: 1rpx solid #eef0e8;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef0e8;
  font-size: 30rpx;
  line-height: 1.55;
}

.detail-label {
  flex: 0 0 208rpx;
  color: #5b6257;
  font-weight: 700;
}

.detail-value {
  flex: 1;
  color: #222820;
  word-break: break-all;
}

.back-button {
  margin-top: 28rpx;
}

.form-title {
  margin-bottom: 24rpx;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.form-error {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #9f352e;
  border-radius: 8rpx;
  background: #fff0ee;
  color: #87251f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field {
  margin-bottom: 24rpx;
}

.field-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.field-label {
  margin-bottom: 12rpx;
  color: #343a32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #cfd8c8;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 30rpx;
  line-height: 1.45;
}

.field-textarea {
  min-height: 144rpx;
}

.category-select-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  margin: 0;
  padding: 16rpx 18rpx;
  border: 1rpx solid #cfd8c8;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: left;
  transition: border-color 160ms ease, background-color 160ms ease;
}

.category-select-button::after {
  border: 0;
}

.category-select-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-select-placeholder {
  color: #7a8175;
  font-weight: 400;
}

.category-select-arrow {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #2f6b48;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.picker-value {
  color: #20231f;
}

.picker-placeholder {
  color: #7a8175;
}

.field-hint {
  margin-top: 10rpx;
  color: #58624f;
  font-size: 26rpx;
  line-height: 1.45;
}

.edit-submit-button {
  background: #215c3a;
}

.empty {
  color: #4a5047;
  text-align: center;
}

.empty-title {
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.empty-desc {
  margin-top: 12rpx;
  color: #58624f;
  font-size: 30rpx;
  line-height: 1.5;
}

.category-panel-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(31, 36, 29, 0.44);
  animation: panel-mask-fade 160ms ease-out;
}

.category-panel {
  box-sizing: border-box;
  width: 100%;
  max-height: 82vh;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  animation: category-panel-rise 160ms ease-out;
}

.category-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.category-panel-title {
  flex: 1;
  min-width: 0;
  color: #20231f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.category-panel-close {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 176rpx;
  min-height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border: 2rpx solid #6a6f78;
  border-radius: 8rpx;
  background: #ffffff;
  color: #4a5059;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
}

.category-panel-close::after {
  border: 0;
}

.category-search-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 84rpx;
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #20231f;
  font-size: 32rpx;
  line-height: 1.4;
}

.category-result-scroll {
  max-height: 560rpx;
}

.category-result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.category-result-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 2rpx solid #c8d2bf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #263022;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: left;
  transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
}

.category-result-button::after {
  border: 0;
}

.category-result-button-active {
  border-color: #215c3a;
  background: #e7f3e9;
  color: #1f5135;
}

.category-result-label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-result-state {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #2f6b48;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.25;
}

.category-search-empty {
  padding: 36rpx 20rpx;
  border: 1rpx solid #dde1d4;
  border-radius: 8rpx;
  background: #fbfcf8;
  color: #4a5047;
  font-size: 32rpx;
  line-height: 1.5;
  text-align: center;
}

@keyframes panel-mask-fade {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes category-panel-rise {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
